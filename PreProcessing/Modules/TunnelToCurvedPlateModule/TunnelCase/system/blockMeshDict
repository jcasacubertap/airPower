boundary
(
    // y=0 mid-plane is internal

    upperWall
    {
        type wall;
        faces
        (
           (4 6 7 5)
        );
    }

    lowerWall
    {
        type wall;
        faces
        (
           (8 10 11 9)
        );
    }

    inlet
    {
        type patch;
        faces
        (
           (0 4 5 1)         // upper inlet
           (8 0 1 9)         // lower inlet
        );
    }

    outlet
    {
        type patch;
        faces
        (
           (2 6 7 3)         // upper outlet
           (10 2 3 11)       // lower outlet
        );
    }

    right
    {
        type            cyclic;
        neighbourPatch  left;
        faces
        (
           (0 2 4 6)
           (8 10 0 2)
        );
    }

    left
    {
        type            cyclic;
        neighbourPatch  right;
        faces
        (
           (1 3 5 7)
           (9 11 1 3)
        );
