FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "../constant/inputParam"

scale 0.001;

// Flat plate length (defined first, used in #calc below)
     xfp ${flowParam.tunnelLength};
// Middle-left coordinates
     xor #calc "-0.5*$xfp";
     yor 0;
// Inlet (top outer) half height
     yi  ${flowParam.tunnelInletHalfHeight};
// Outlet (top outer) half height
     yo  ${flowParam.tunnelOutletHalfHeight};
// z-planes [mm] (quasi-2D, cyclic)
     z0  -10;
     z1   10;
// Grid partitions
     Nx  ${flowParam.Nx};
     Ny  ${flowParam.Ny};
// BSpline control points
     xcp1 ${flowParam.xcp1};
     ycp1 ${flowParam.ycp1};
     xcp2 ${flowParam.xcp2};
     ycp2 ${flowParam.ycp2};
     xcp3 ${flowParam.xcp3};
     ycp3 ${flowParam.ycp3};

vertices
(
    // Mid-plane (y = 0)
    ($xor $yor $z1)                         // 0
    ($xor $yor $z0)                         // 1
    (#calc "0.5*$xfp" $yor $z1)             // 2
    (#calc "0.5*$xfp" $yor $z0)             // 3

    // Upper outer line (y > 0)
    ($xor $yi $z1)                          // 4
    ($xor $yi $z0)                          // 5
    (#calc "0.5*$xfp" $yo $z1)              // 6
    (#calc "0.5*$xfp" $yo $z0)              // 7

    // Lower outer line (mirrored, y < 0)
    ($xor #calc "-1*$yi" $z1)               // 8
    ($xor #calc "-1*$yi" $z0)               // 9
    (#calc "0.5*$xfp" #calc "-1*$yo" $z1)   // 10
    (#calc "0.5*$xfp" #calc "-1*$yo" $z0)   // 11
);

blocks
(
    // Upper half: mid-plane -> top
    hex (0 2 3 1 4 6 7 5) internalDuct ($Nx 2 $Ny) simpleGrading (1 1 0.1)

    // Lower half: mid-plane -> bottom 
    hex (1 3 2 0 9 11 10 8) internalDuct ($Nx 2 $Ny) simpleGrading (1 1 0.1)
);

