#!/bin/sh

rm -rf dynamicCode
rm -rf postProcessing

# Find the latest reconstructed time directory
latestTime=$(ls -1d [0-9]* 2>/dev/null | sort -g | tail -1)

if [ -z "$latestTime" ] || [ "$latestTime" = "0" ]; then
    echo "Error: no solved time directories found"
    exit 1
fi

echo "Post-processing time = $latestTime"

# Step 1: Compute wallShearStress and yPlus fields (writes to time directory)
simpleFoam -postProcess -func wallShearStress -time "$latestTime"
simpleFoam -postProcess -func yPlus -time "$latestTime"

# Step 2: Run all controlDict function objects (writeMidPlane + solverInfo)
simpleFoam -postProcess -time "$latestTime"
