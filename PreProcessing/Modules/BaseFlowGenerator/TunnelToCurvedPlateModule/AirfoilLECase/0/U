FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "../constant/inputParam"

Uinf            ${Upinlet.Uinf};

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform ($Uinf 0 0);

boundaryField
{
    airfoil
    {
        type            noSlip;
    }
    farfield
    {
        type            fixedValue;
        value           $internalField;
    }
    suctionOutlet
    {
        type            zeroGradient;
    }
    pressureOutlet
    {
        type            zeroGradient;
    }
    front
    {
        type            empty;
    }
    back
    {
        type            empty;
    }
}

