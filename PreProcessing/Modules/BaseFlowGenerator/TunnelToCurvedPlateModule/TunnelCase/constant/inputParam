FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      inputParam;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

flowParam
{
//1.- Tunnel Geometrical Parameters

 //Basic geometry

 tunnelInletHeight     900.0;        // [mm] (tunnel half height)

 tunnelOutletHeight    900.0;        // [mm] (nule, it applies as Control Point)

 flatPlateLength       7800;         //[mm]

 z0                    -10;          // first z-plane [mm]
 z1                     10;          // second z-plane [mm]  (quasi-2D thickness)

 // Secondary geometrical parameters (optional for more elaborate analyses)

 seleAR                4;            // [-] (optional, to include a flat plate with LE)

 seleHalfThickness     10;           // [mm] (optional, to include a flat plate with LE)

 lamTurbHeight         40;           // [mm] (optional, region to on/off RANS modelling)

//2.- Grid Discretization Parameters

 //Streamwise partitions
 Nx 210;                             // [-]

 //Wall-normal partitions
 Ny 60;                              // [-]

//3.- Flow Parameters (m as dimensional units)

 freeStreamVelocity    24.84840467482210;       //[ms^1]

 freeStreamViscosity   1.456610719354608e-5;    //[m^2s^1]

//4.- Turbulence Parameters

 turbulenceIntensity   0.0003;        //[-] (eg, I = 0.03%, is I = 0.0003, LTT of TU Delft) (k = 1.5 * (I U)^2)
 turbLengthScale       0.009;         //[m] (freestream eddy size) (omega = (k^0.5) / (0.09^0.25 L))

//5.- BSpline Control Points

 xcp1 -1950;
 ycp1 900;

 xcp2 0;
 ycp2 900;

 xcp3 1950;
 ycp3 900;
}

