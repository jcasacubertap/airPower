FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "../constant/inputParam"

kInlet          #calc "1.5 * pow($flowParam.freeStreamVelocity * $flowParam.turbulenceIntensity, 2)";

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform $kInlet;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    } 
    airfoil
    {
        type            kqRWallFunction;
        value           $internalField;
    }
    left
    {
        type            symmetryPlane;
    }
    right
    {
        type            symmetryPlane;
    }
    upperWall
    {
        type            kqRWallFunction;
        value           $internalField;
    }
    lowerWall
    {
        type            kqRWallFunction;
        value           $internalField;
    }
}


