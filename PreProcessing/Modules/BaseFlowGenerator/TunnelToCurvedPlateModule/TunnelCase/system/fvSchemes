FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         steadyState;
}

// Evaluation of grad() terms by use of Gauss' theorem;
// ie., grad(r) = (1/V) Sum(r · S)
gradSchemes
{
    default         Gauss linear;
}
// Gauss linear: computes face values with linear interpolation
// from neighbouring cell centers -> therefore it's 2nd-order accurate
//
// Gauss  cubic: same idea, but higher order

divSchemes
{
    default         none;
    div(phi,U)      bounded Gauss linearUpwind grad(U);
    div(phi,k)      bounded Gauss limitedLinear 1;
    div(phi,omega)  bounded Gauss limitedLinear 1;
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
    div(nonlinearStress) Gauss linear;
}
// Second-oder momentum convection with an upstream upwind bias

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method meshWave;
}


