#!/bin/sh

NP=${1:-8}

rm -rf dynamicCode
rm -rf postProcessing/midPlane.*

# Find the latest time directory in processor0
latestTime=$(ls -1d processor0/[0-9]* 2>/dev/null | sort -t/ -k2 -g | tail -1 | cut -d/ -f2)

if [ -z "$latestTime" ] || [ "$latestTime" = "0" ]; then
    echo "Error: no solved time directories found in processor0/"
    exit 1
fi

echo "Post-processing time = $latestTime"
mpirun -np "$NP" --oversubscribe simpleFoam -parallel -postProcess -time "$latestTime"
