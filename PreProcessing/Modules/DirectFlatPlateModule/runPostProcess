#!/bin/sh

rm -rf dynamicCode
rm -rf postProcessing/midPlane.*

# Find the latest reconstructed time directory
latestTime=$(ls -1d [0-9]* 2>/dev/null | sort -g | tail -1)

if [ -z "$latestTime" ] || [ "$latestTime" = "0" ]; then
    echo "Error: no solved time directories found"
    exit 1
fi

echo "Post-processing time = $latestTime"
simpleFoam -postProcess -time "$latestTime"
