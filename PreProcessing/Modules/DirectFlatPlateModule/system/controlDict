FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         100000;

deltaT          1;

writeControl    timeStep;

writeInterval   #calc "$endTime / 100" ;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    solverInfo
    {
        type            solverInfo;
        libs            ("libutilityFunctionObjects.so");
        writeResidualFields no;
        fields          ("U" "p");
    }

    yPlus
    {
        type                 yPlus;
        libs                 ("libfieldFunctionObjects.so");
        executeControl       writeTime;
        writeControl         writeTime;
    }

    writeMidPlane
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            writeMidPlane;
        executeControl  writeTime;
        writeControl    none;

        codeInclude
        #{
            #include "OFstream.H"
            #include <fstream>
        #};

        codeExecute
        #{
            const fvMesh& mesh = refCast<const fvMesh>(obr_);
            const volVectorField& U =
                mesh.lookupObject<volVectorField>("U");
            const volScalarField& p =
                mesh.lookupObject<volScalarField>("p");
            const vectorField& C = mesh.C();

            // Read output format from inputParam
            IOdictionary inputParam
            (
                IOobject
                (
                    "inputParam", "constant", mesh,
                    IOobject::MUST_READ, IOobject::NO_WRITE
                )
            );
            const dictionary& d = inputParam.subDict("Upinlet");
            const word fmt = d.lookupOrDefault<word>("outputFormat", "csv");
            const bool wallExtrap = d.lookupOrDefault<bool>("wallExtrapolation", false);

            const scalar zTarget = 0.0;
            const scalar zTol    = 1e-3;

            // Collect cells on the mid-plane
            DynamicList<label> cells;
            forAll(C, cellI)
            {
                if (mag(C[cellI].z() - zTarget) < zTol)
                {
                    cells.append(cellI);
                }
            }

            // ── Wall extrapolation: add wall face centres with u=v=w=0 ──
            // Wall pressure is taken from the BC value (pw[fi]). For the
            // standard zeroGradient pressure BC this equals the owner-cell
            // pressure — the same value OpenFOAM integrates for forces and
            // the same one already exported in wall-quantity outputs.
            // The previous 2-point linear extrapolation assumed a vertical
            // wall normal (dist = C[ci].y() - fy) and a tight x-column
            // filter; both assumptions break on the bump's sloped region,
            // producing the same kind of artifacts seen in AirfoilLECase.
            DynamicList<label> wallFaces;
            DynamicList<scalar> wallP;
            if (wallExtrap)
            {
                label patchID = mesh.boundaryMesh().findPatchID("plate");
                if (patchID >= 0)
                {
                    const polyPatch& pp = mesh.boundaryMesh()[patchID];
                    const vectorField faceCentres(pp.faceCentres());  // copy to avoid dangling ref
                    const fvPatchScalarField& pw = p.boundaryField()[patchID];

                    forAll(faceCentres, fi)
                    {
                        if (mag(faceCentres[fi].z() - zTarget) > zTol) continue;
                        wallFaces.append(fi);
                        wallP.append(pw[fi]);
                    }

                    Info<< "writeMidPlane: wall extrapolation — "
                        << wallFaces.size() << " wall faces added" << endl;
                }
            }

            const fileName outDir =
                mesh.time().globalPath()/"postProcessing";
            mkDir(outDir);

            label totalRows = cells.size() + wallFaces.size();

            if (fmt == "binary")
            {
                const fileName fpath = outDir/"midPlane.bin";
                std::ofstream ofs(fpath, std::ios::binary);

                int32_t nCols = 7;
                int64_t nRows = totalRows;
                ofs.write(reinterpret_cast<const char*>(&nCols), sizeof(nCols));
                ofs.write(reinterpret_cast<const char*>(&nRows), sizeof(nRows));

                // Interior cells
                forAll(cells, i)
                {
                    const label ci = cells[i];
                    double row[7] =
                    {
                        C[ci].x(), C[ci].y(), C[ci].z(),
                        U[ci].x(), U[ci].y(), U[ci].z(),
                        p[ci]
                    };
                    ofs.write(reinterpret_cast<const char*>(row), sizeof(row));
                }

                // Wall points (u=v=w=0, p extrapolated)
                if (wallExtrap)
                {
                    label patchID = mesh.boundaryMesh().findPatchID("plate");
                    const vectorField fc(mesh.boundaryMesh()[patchID].faceCentres());
                    forAll(wallFaces, i)
                    {
                        label fi = wallFaces[i];
                        double row[7] =
                        {
                            fc[fi].x(), fc[fi].y(), fc[fi].z(),
                            0.0, 0.0, 0.0,
                            wallP[i]
                        };
                        ofs.write(reinterpret_cast<const char*>(row), sizeof(row));
                    }
                }

                Info<< "writeMidPlane: wrote " << totalRows
                    << " rows (binary) to " << fpath << endl;
            }
            else
            {
                OFstream os(outDir/"midPlane.csv");
                os.precision(10);
                os << "x,y,z,u,v,w,p" << nl;

                // Interior cells
                forAll(cells, i)
                {
                    const label ci = cells[i];
                    os  << C[ci].x() << ","
                        << C[ci].y() << ","
                        << C[ci].z() << ","
                        << U[ci].x() << ","
                        << U[ci].y() << ","
                        << U[ci].z() << ","
                        << p[ci] << nl;
                }

                // Wall points (u=v=w=0, p extrapolated)
                if (wallExtrap)
                {
                    label patchID = mesh.boundaryMesh().findPatchID("plate");
                    const vectorField fc(mesh.boundaryMesh()[patchID].faceCentres());
                    forAll(wallFaces, i)
                    {
                        label fi = wallFaces[i];
                        os  << fc[fi].x() << ","
                            << fc[fi].y() << ","
                            << fc[fi].z() << ","
                            << 0.0 << ","
                            << 0.0 << ","
                            << 0.0 << ","
                            << wallP[i] << nl;
                    }
                }

                Info<< "writeMidPlane: wrote " << totalRows
                    << " rows (csv) to " << os.name() << endl;
            }
        #};
    }
}


