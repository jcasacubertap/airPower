FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "../constant/inputParam"

convertToMeters 0.001;

// Domain dimensions [m -> mm for convertToMeters 0.001]
Lm   ${Upinlet.domainLength};
Hm   ${Upinlet.domainHeight};
L    #calc "$Lm * 1000.0";
H    #calc "$Hm * 1000.0";

// Block x-positions (fixed proportions)
x0   0;
x1   #calc "3.0/13.0 * $L";
x2   #calc "7.0/26.0 * $L";
x3   #calc "9.0/26.0 * $L";
x4   #calc "5.0/13.0 * $L";
x5   #calc "11.0/13.0 * $L";
x6   $L;

// Block y-positions (50/50 split)
y0   0;
y1   #calc "0.5 * $H";
y2   $H;

// Spanwise [mm] (quasi-2D, cyclic)
z0   -1;
z1    1;

vertices
(
($x0 $y0 $z0)
($x1 $y0 $z0)
($x2 $y0 $z0)
($x3 $y0 $z0)
($x4 $y0 $z0)
