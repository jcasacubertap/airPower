($x5 $y1 $z1)
($x6 $y1 $z1)
($x0 $y2 $z1)
($x1 $y2 $z1)
($x2 $y2 $z1)
($x3 $y2 $z1)
($x4 $y2 $z1)
($x5 $y2 $z1)
($x6 $y2 $z1)
);
// Grid resolution factors from inputParam
gx   ${Upinlet.gridXfactor};
gy   ${Upinlet.gridYfactor};

// Base cell counts scaled by factors
Nx1  #calc "36 * $gx";
Nx2  #calc "6  * $gx";
Nx3  #calc "12 * $gx";
Nx4  #calc "6  * $gx";
Nx5  #calc "70 * $gx";
Nx6  #calc "24 * $gx";
NyB  #calc "30 * $gy";
NyT  #calc "10 * $gy";

blocks
(
//Block 1: inlet bottom
hex (0 1 8 7 21 22 29 28) ($Nx1 $NyB 2) simpleGrading (1 18 1)
//Block 2: pre-central region bottom
hex (1 2 9 8 22 23 30 29) ($Nx2 $NyB 2) simpleGrading (1 18 1)
//Block 3: central region bottom
hex (2 3 10 9 23 24 31 30) ($Nx3 $NyB 2) simpleGrading (1 18 1)
